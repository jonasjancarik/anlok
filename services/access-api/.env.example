PORT=8000
RFID_LENGTH=10
PIN_LENGTH=4
INPUT_TIMEOUT=10  # seconds within which the PIN must be entered

# AWS credentials for the SES service
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SES_SENDER_EMAIL=
AWS_REGION=

# Login email links
# WEB_APP_URL is used with /login.
WEB_APP_URL=http://localhost:3000

# Optional Expo push security token. Set this only if enhanced push security is
# enabled for the Expo project.
EXPO_PUSH_ACCESS_TOKEN=

# GPIO pin for the relay
RELAY_PIN=18
RELAY_ACTIVE_STATE=LOW  # LOW or HIGH - depends on the type of relay
RELAY_ACTIVATION_TIME=10

# Reader mode - stdin for keyboard input from the terminal, evdev for a USB keyboard input, or t9em (see readme)
INPUT_SOURCE=evdev
